	// This function returns the credentials for the database connection
	// depending on the environment (dev or prod).

	// It takes a parameter $selectDB which can be either 'dev' or 'prod'.
	// It returns an associative array with the server, user, password, and database name.
	// Usage: sql::sql_run("SELECT * FROM table_name", 'dev');
	// Example: sql::sql_run("SELECT * FROM users", 'prod');

	private static $environment = 'dev'; // Change to 'prod' for production environment

	public static function loadEnvIni($path) {

		if (!file_exists($path)) {
			return [];
		}
		
		$content = file_get_contents($path);
		$lines = explode("\n", $content);
		$config = [];
		
		foreach ($lines as $line) {
			$line = trim($line);
			if (!empty($line) && strpos($line, '=') !== false && strpos($line, '#') !== 0) {
				list($key, $value) = explode('=', $line, 2);
				$key = trim($key);
				$value = trim($value);
				
				// Remove quotes
				$value = trim($value, '"\'');
				
				$config[$key] = $value;
				putenv("$key=$value");
				$_ENV[$key] = $value;
			}
		}
		
		return $config;
	}

