	public static function sql_run($query) {

		// loadEnv::loadEnv();

		$dbInfo = self::credentials(self::$environment);
		$link = mysqli_connect($dbInfo['server'], $dbInfo['user'], $dbInfo['password'], $dbInfo['database']);


		if (!$link) {
			echo "Error: Unable to connect to MySQL." . PHP_EOL;
			echo "Debugging errno: " . mysqli_connect_errno() . PHP_EOL;
			exit;
		}

		//	or die("could not connect : " . mysqli_error());
		// mysql_select_db("msi") or die("could not select database" . mysql_error());
		$result = mysqli_query($link,$query) or die("query failed : " . mysqli_error($link));
		$values = [];

		//To prevent error generated by: num_fields(),foreach, ect when given $res generated by 'UPDATE',ect.
		//#stristr is case-insensetive
		if (stristr($query,'INSERT') == false && stristr($query,'DELETE') == false && stristr($query,'UPDATE') == false) {

			//I(Tim) changed from mysql_fetch_row => fetch_array, as item can be retrived by both numeric and col names
			while ($fields = mysqli_fetch_array ($result)){
				$values[] = $fields;
			}
			mysqli_free_result($result);
		} else {
			$values = ['status' => $result]; // Return null for non-SELECT queries
		}
		
		mysqli_close($link);
		
		return $values;
	}

